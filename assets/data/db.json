{
  "projects": [
    {
      "id_project": 1,
      "name": "Reforestación Manglar Nicoya",
      "slug": "reforestacion-manglar-nicoya",
      "description": "Proyecto de recuperación del ecosistema de manglar en las costas de Nicoya mediante siembra de mangle rojo, blanco y negro.",
      "observations": "Incluye monitoreo mensual de biodiversidad y capacitación a comunidades locales. Alianza con comunidad indígena de Barra Honda.",
      "aim": "Recuperar 500 hectáreas de manglar antes de 2026",
      "start_date": "2025-01-15T00:00:00.000000"
    },
    {
      "id_project": 2,
      "name": "Educación Ambiental Escuelas Chorotega",
      "slug": "educacion-ambiental-chorotega",
      "description": "Programa de visitas educativas a 12 escuelas de la región Chorotega para fomentar la conciencia ambiental.",
      "observations": "Se desarrollan talleres interactivos sobre biodiversidad, agua y manejo de residuos. Alcance: 2500 estudiantes aproximadamente.",
      "aim": "Alcanzar 1200 estudiantes con contenido ambiental",
      "start_date": "2025-03-01T00:00:00.000000"
    },
    {
      "id_project": 3,
      "name": "Limpieza de Playas Carrillo",
      "slug": "limpieza-playas-carrillo",
      "description": "Campaña trimestral de limpieza de playas del Pacífico Norte con participación comunitaria.",
      "observations": "Se recolectó y clasificó más de 2 toneladas de residuos durante las tres jornadas realizadas. Colaboración con operadores turísticos.",
      "aim": "Mantener playas limpias durante todo el año",
      "start_date": "2024-07-01T00:00:00.000000"
    },
    {
      "id_project": 4,
      "name": "Monitoreo Tortugas Baulas",
      "slug": "monitoreo-tortugas-baulas",
      "description": "Programa nocturno de monitoreo y protección de nidos de tortuga baula en playa Ostional.",
      "observations": "Incluye conteo de hembras anidantes, marcaje y registro de datos de incubación. Temporada alta: junio a diciembre.",
      "aim": "Proteger 10000 nidos en la temporada 2025-2026",
      "start_date": "2025-06-01T00:00:00.000000"
    },
    {
      "id_project": 5,
      "name": "Huertos Comunitarios Nicoya",
      "slug": "huertos-comunitarios-nicoya",
      "description": "Establecimiento de huertos orgánicos en cinco comunidades rurales de Nicoya.",
      "observations": "Promueve la seguridad alimentaria y técnicas de agricultura sostenible. Beneficiarios: 150 familias rurales.",
      "aim": "Crear 5 huertos productivos en comunidades rurales",
      "start_date": "2025-02-01T00:00:00.000000"
    },
    {
      "id_project": 6,
      "name": "Conservación de Bosque Seco Tropical",
      "slug": "conservacion-bosque-seco",
      "description": "Protección y restauración del bosque seco tropical en la Península de Santa Elena.",
      "observations": "Especie endémica: Guanacaste. Investigación científica con Universidad de Costa Rica.",
      "aim": "Proteger 2000 hectáreas de bosque seco",
      "start_date": "2025-04-10T00:00:00.000000"
    }
  ],
  "activities": [
